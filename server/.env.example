# Server Environment Variables
# Copy this to .env and fill in the values

# Server Port (Railway/Render will set this automatically)
PORT=3000

# MongoDB Connection String
# Get this from MongoDB Atlas - https://www.mongodb.com/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/meettd

# JWT Secret Key (generate a random 32+ character string)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Client URL (your Vercel frontend URL - no trailing slash)
# Example: https://meettd.vercel.app
CLIENT_URL=https://your-frontend-url.vercel.app
